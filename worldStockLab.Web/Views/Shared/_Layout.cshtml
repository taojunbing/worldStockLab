<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] ?? "WorldStockLab"</title>
    <meta name="description" content="@ViewData["Description"]" />
    <meta name="keywords" content="stock, ETF, Nasdaq 100, trading, analysis" />

    <meta property="og:title" content="@ViewData["Title"]" />
<meta property="og:description" content="@ViewData["Description"]" />
<meta property="og:type" content="website" />
<meta property="og:url" content="@Context.Request.Path" />


    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" /> 
    <link rel="stylesheet" href="~/css/site-finance.css" />

</head>

<body>

    <!-- ⭐ Navbar（已居中对齐） -->
    <nav class="navbar navbar-expand-lg">
        <div class="container-main d-flex align-items-center">

            <a class="navbar-brand" href="/">🌍 WorldStockLab</a>

            <div class="ms-auto d-flex align-items-center">

                <ul class="navbar-nav flex-grow-1 align-items-center">

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">首页</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Stock" asp-action="Index">全球股票</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Blog" asp-action="Index">博客</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark"  asp-controller="Home" asp-action="About">关于</a>
                    </li>

                    <!-- 博客搜索 -->
                    <li class="nav-item ms-3">
                        <form method="get" action="/search" style="display:flex;">
                            <input type="text" name="q" placeholder="搜索文章" style="width:150px;" />
                            <button type="submit">搜索</button>
                        </form>
                    </li>

                    <!-- 股票搜索（独立！关键） -->
                    <li class="nav-item ms-3" style="position:relative;">
                        <div class="nav-search ms-3">
                        <input type="text"
                               id="stockSearchBox"
                               placeholder="Search stock (AAPL, NVDA)"
                               autocomplete="off"
                             />
                        </div>
                        

                        <!-- 自动补全 -->
                        <div id="stockResults"
                             style="
                            position:absolute;
                            top:35px;
                            left:0;
                            right:0;
                            background:white;
                            border:1px solid #ccc;
                            display:none;
                            z-index:999;
                            ">
                        </div>

                    </li>

                </ul>

               

            </div>

        </div>
    </nav>

    <!-- ⭐ 顶部行情条 -->
    @if (ViewBag.Stocks != null)
{
    <div class="ticker-bar">
        @foreach (var s in ViewBag.Stocks as List<StockPrice>)
        {
            <span class="ticker-item">
                <a href="/stock/detail/@s.Symbol">@s.Symbol</a>
                @s.Price
                <span class="@(s.ChangePercent > 0 ? "up" : "down")">
                    @s.ChangePercent %
                </span>
            </span>
        }
    </div>
}
    <!-- ⭐ 主体内容 -->
    <div class="container-main">
        @RenderBody()
    </div>
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - worldStockLab.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            <a href="/rss">RSS订阅</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>

            document.addEventListener("DOMContentLoaded", function () {

                // 获取元素（此时一定存在）
                const box = document.getElementById("stockSearchBox");
                const results = document.getElementById("stockResults");

                if (!box || !results) {
                    console.error("搜索框未找到");
                    return;
                }

                // 输入监听
                box.addEventListener("input", async function () {

                    const q = box.value;

                    if (q.length < 1) {
                        results.style.display = "none";
                        return;
                    }

                    const res = await fetch("/search/stocks?query=" + q);
                    const data = await res.json();

                    let html = "";

                    data.forEach(symbol => {
                        html += `
                            <div class="item" style="padding:5px; cursor:pointer;">
                                ${symbol}
                            </div>
                        `;
                    });

                    results.innerHTML = html;
                    results.style.display = "block";

                    document.querySelectorAll(".item").forEach(el => {
                        el.addEventListener("click", function () {
                            window.location.href = "/stock/detail/" + this.innerText;
                        });
                    });

                });

                // 回车跳转
                box.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        const symbol = box.value.toUpperCase();
                        if (symbol) {
                            window.location.href = "/stock/detail/" + symbol;
                        }
                    }
                });

            });

    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>