@using worldStockLab.Web.Models
@model List<Article>



<h2>博客文章</h2>

@foreach (var article in Model)
{
    <div style="margin-bottom:20px">

        <!-- 文章标题 -->
        <h3>
            <a href="/blog/@article.Slug">
                @article.Title
            </a>
        </h3>

        <!-- 摘要 -->
        <p>@article.Summary</p>

        <!-- 分类和时间 -->
        <small>
            分类：@article.Category |
            发布时间：@article.CreatedAt.ToString("yyyy-MM-dd")
        </small>

    </div>
}