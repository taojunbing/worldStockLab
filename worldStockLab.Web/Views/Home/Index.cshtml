<!-- #region 新版 -->
@model HomeViewModel
<link rel="stylesheet" href="~/css/site-finance.css" />
<style>

    .category-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 20px;
}

.row {
    display: flex;
    justify-content: space-between;
    padding: 6px 0;
}

.card h2 {
    margin-bottom: 10px;
}

    .row-item {
        display: flex;
        justify-content: space-between;
        padding: 6px 0;
    }
    .stock-row a {
    font-weight: 600;
    color: var(--blue);
    }
    .stock-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;

    padding: 10px 0;
    border-bottom: 1px solid var(--border);
}

.left {
    font-weight: 600;
}

.center {
    text-align: center;
}

.right {
    text-align: right;
}


.card h4 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 10px;
}

.sidebar .card {
    border-left: 3px solid var(--primary);
}
.views {
    font-size: 12px;
    color: var(--muted);
}
    .tag {
    background: #f3f4f6;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 11px;
}
.card:hover {
    transform: translateY(-2px);
}
a {
    transition: 0.2s;
}
</style>

<!--首页加模块-->
<div class="index-grid">

    <div class="index-card">
        <h3>道琼斯</h3>
        <div class="price">@ViewBag.Dow.Price</div>
        <div class="change @(ViewBag.Dow.ChangePercent > 0 ? "up" : "down")">
            @ViewBag.Dow.Change (@ViewBag.Dow.ChangePercent %)
        </div>
    </div>

    <div class="index-card">
        <h3>纳斯达克</h3>
        <div class="price">@ViewBag.Nasdaq.Price</div>
        <div class="change @(ViewBag.Nasdaq.ChangePercent > 0 ? "up" : "down")">
            @ViewBag.Nasdaq.Change (@ViewBag.Nasdaq.ChangePercent %)
        </div>
    </div>

    <div class="index-card">
        <h3>标普500</h3>
        <div class="price">@ViewBag.Sp500.Price</div>
        <div class="change @(ViewBag.Sp500.ChangePercent > 0 ? "up" : "down")">
            @ViewBag.Sp500.Change (@ViewBag.Sp500.ChangePercent %)
        </div>
    </div>

</div>



<div class="layout">

    <!-- 左：主内容 -->
    <div class="main">

        @{
    var ai = ViewBag.AIStocks as List<StockPrice>;
    var etf = ViewBag.ETFStocks as List<StockPrice>;
    var semi = ViewBag.SemiStocks as List<StockPrice>;
}
 <!-- 恐惧与贪婪指数 -->
 <div class="card">
    <h2>😨 Fear & Greed Index</h2>

    <div class="fear-value">
        @ViewBag.FearIndex
    </div>

    <div class="fear-label">
        @{
            var val = (int)ViewBag.FearIndex;
        }

        @if (val < 25)
        {
            <span class="down">Extreme Fear</span>
        }
        else if (val < 50)
        {
            <span>Fear</span>
        }
        else if (val < 75)
        {
            <span>Greed</span>
        }
        else
        {
            <span class="up">Extreme Greed</span>
        }
    </div>
</div>

<div class="category-grid">

    <!-- AI -->
    <div class="card">
        <h2>🧠 AI & Cloud</h2>

        @foreach (var s in ai)
        {
            <div class="row">
                <a href="/stock/detail/@s.Symbol">@s.Symbol</a>
                <span class="@(s.ChangePercent >= 0 ? "up" : "down")">
                    @s.ChangePercent %
                </span>
            </div>
        }
    </div>

    <!-- ETF -->
    <div class="card">
        <h2>⚡ Leveraged ETF</h2>

        @foreach (var s in etf)
        {
            <div class="row">
                <a href="/stock/detail/@s.Symbol">@s.Symbol</a>
                <span class="@(s.ChangePercent >= 0 ? "up" : "down")">
                    @s.ChangePercent %
                </span>
            </div>
        }
    </div>

    <!-- 半导体 -->
    <div class="card">
        <h2>🔌 Semiconductor</h2>

        @foreach (var s in semi)
        {
            <div class="row">
                <a href="/stock/detail/@s.Symbol">@s.Symbol</a>
                <span class="@(s.ChangePercent >= 0 ? "up" : "down")">
                    @s.ChangePercent %
                </span>
            </div>
        }
    </div>

</div>

        <!-- 市场 -->
        <div class="card market">
            <h3 style="margin-bottom:15px;">📊 Market Snapshot市场热点</h3>

            @foreach (var s in Model.Stocks)
            {
                <div class="stock-row">
    <div class="left">
        <a href="/stock/detail/@s.Symbol">@s.Symbol</a>
    </div>

    <div class="center">
        @s.Price
    </div>

    <div class="right @(s.ChangePercent > 0 ? "up" : "down")">
        @s.ChangePercent %
    </div>
</div>
            }
        </div>

        <!-- 文章 -->
        <div class="card">
            <h3>📝 Latest Analysis</h3>

            @foreach (var a in Model.Articles)
            {
               <div class="article">
    <a href="/blog/@a.Slug">@a.Title</a>

    <div class="meta">
        <span class="tag">@a.Symbol</span>
        · @a.CreatedAt.ToShortDateString()
    </div>
</div>
            }
        </div>

    </div>

    <!-- 右：侧栏 -->
    <div class="sidebar">

        <div class="card">
            <h4>🔥 Hot Stocks</h4>

            @foreach (var s in Model.HotStocks)
            {
                <div class="stock-row">
                    <a href="/stock/detail/@s.Symbol">@s.Symbol</a>
                   <div class="views">
        👁 @s.ViewCount
    </div>
                </div>
            }
        </div>

        <div class="card">
            <h4>🚀 Top Gainers</h4>

            @foreach (var s in Model.Gainers)
            {
                <div class="stock-row">
                    <a href="/stock/detail/@s.Symbol">@s.Symbol</a>
                    <span class="up">@s.ChangePercent %</span>
                </div>
            }
        </div>

        <div class="card">
            <h4>📉 Top Losers</h4>

            @foreach (var s in Model.Losers)
            {
                <div class="stock-row">
                    <a href="/stock/detail/@s.Symbol">@s.Symbol</a>
                    <span class="down">@s.ChangePercent %</span>
                </div>
            }
        </div>

    </div>

</div>