@using worldStockLab.Web.Models
@model Article

<link rel="stylesheet"
      href="https://uicdn.toast.com/editor/latest/toastui-editor.min.css" />

<h2>发布文章</h2>

<form asp-action="Create" method="post"
      onsubmit="document.getElementById('Content').value = editor.getMarkdown();">

    @Html.AntiForgeryToken()

    <div class="form-group">
        <label>标题</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="form-group">
        <label>分类</label>
        <input asp-for="Category" class="form-control" />
    </div>

    <div class="form-group">
        <label>摘要</label>
        <textarea asp-for="Summary" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>正文</label>

        <div id="editor"></div>

        <!-- 关键字段 -->
        <input type="hidden" asp-for="Content" id="Content" />
    </div>

    <!-- 🚨 直接 submit -->
    <button type="submit" class="btn btn-primary">
        发布
    </button>
</form>

<script src="https://uicdn.toast.com/editor/latest/toastui-editor-all.min.js"></script>

<script>
    // 全局 editor（关键）
    const editor = new toastui.Editor({
    el: document.getElementById('editor'),
    height: '400px',
    initialEditType: 'markdown',
    previewStyle: 'vertical'
    });

    console.log("✅ editor 初始化成功");
</script>